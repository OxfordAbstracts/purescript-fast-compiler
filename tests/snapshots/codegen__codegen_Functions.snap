    return f(x);
  };
};

var flip: <A, B, C>(x: (x: A) => (x: B) => C) => (x: B) => (x: A) => C = function(f) {
  return function(b) {
    return function(a) {
      return f(a)(b);
    };
  };
};

var compose: <A, B, C>(x: (x: B) => C) => (x: (x: A) => B) => (x: A) => C = function(f) {
  return function(g) {
    return function(x) {
      return f(g(x));
    };
  };
};


