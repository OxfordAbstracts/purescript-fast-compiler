    if (c instanceof Types.Red) {
        return true;
    }
    return false;
};
var fromMaybe = function (def) {
    return function (m) {
        if (m instanceof Types.Nothing) {
            return def;
        }
        if (m instanceof Types.Just) {
            return m.value0;
        }
        console.error("Failed pattern match at value:", m);
        console.error("Type:", typeof m);
        throw new Error("Failed pattern match");
    };
};
