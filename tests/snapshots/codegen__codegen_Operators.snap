var applyFn: any = function(f) {
  return function(x) {
    return f(x);
  };
};

var $dollar = applyFn;

var useOp: (x: number) => number = function(x) {
  return add(x)(x);
};

var useDollar: (x: number) => number = function(x) {
  return useOp(x);
};


