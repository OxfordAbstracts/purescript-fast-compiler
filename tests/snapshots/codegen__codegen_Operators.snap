var add = function(a) {
  return function(b) {
    return a;
  };
};

var $plus = add;

var applyFn = function(f) {
  return function(x) {
    return f(x);
  };
};

var $dollar = applyFn;

var useOp = function(x) {
  return add(x)(x);
};

var useDollar = function(x) {
  return useOp(x);
};


export { $dollar, $plus, add, applyFn, useDollar, useOp };
