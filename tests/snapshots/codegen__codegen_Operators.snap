var applyFn = function (f) {
    return function (x) {
        return f(x);
    };
};
var add = function (a) {
    return function (b) {
        return a;
    };
};
var useOp = function (x) {
    return add(x)(x);
};
var useDollar = function (x) {
    return applyFn(useOp)(x);
};
export {
    add,
    useOp,
    applyFn,
    useDollar
};
