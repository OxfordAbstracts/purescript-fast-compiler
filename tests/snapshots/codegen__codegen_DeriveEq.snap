var eqMaybe: ($dictEq: Eq<any>) => Eq<Maybe<any>> = function($dictEq) {
  return {
    eq: function(x: any) {
      return function(y: any) {
        if (x instanceof Nothing && y instanceof Nothing) {
          return true;
